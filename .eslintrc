{
  "parser": "babel-eslint",
  "extends": "airbnb",
  "ecmaFeatures": {
    "modules": true,
    "es6": true,
    "jsx": true,
    "browser": true
  },
  "rules": {
    "semi": 0,
    "arrow-parens": 0,
    "no-comma-dangle": 0,
    "comma-dangle": 0,
    "no-unused-vars": 0,
    "padded-blocks": 0,
    "no-console": 0,
    "arrow-body-style": 0,
    "space-before-function-paren": 0,
    "bject-curly-spacing": 0,
    "no-debugger": 0,
    "react/prop-types": 0,
    "space-in-parens": 0,
    "no-multi-spaces": 0,
    "no-restricted-syntax": 0,
    "no-prototype-builtins": 0,

    "global-require": 0,
    "no-param-reassign": 0,
    "object-curly-spacing": 2,
    "max-len": ["error", 120],
    "id-length": [
      2, {"min": 2, "properties": "never", "exceptions": ["x", "n", "i", "e", "$", "_", "g", "A"]}
    ],
    "react/no-array-index-key": 0
  },
  "settings": {
    "import/ignore": ["node_modules"],
    "import/resolver": {
      "webpack": {
        "config": "webpack/dev.config.babel"
      }
    }
  },
  "globals": {
    "document": true
  }
}
